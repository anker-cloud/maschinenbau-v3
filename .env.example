# ============================================================
# Sturtz Maschinenbau Support Chatbot — Environment Variables
# ============================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env to source control.

# ----- PostgreSQL -----
POSTGRES_PASSWORD=changeme_strong_password   # REQUIRED
POSTGRES_USER=postgres                        # optional, default: postgres
POSTGRES_DB=sturtz                            # optional, default: sturtz

# ----- Authentication -----
JWT_SECRET=replace_with_long_random_secret   # REQUIRED — min 32 chars
RAG_INTERNAL_SECRET=replace_with_random_secret  # REQUIRED in production

# ----- AWS -----
# Used by: pageindex (Bedrock LLM), rag-service (Bedrock + S3), api-server (S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...                    # REQUIRED
AWS_SECRET_ACCESS_KEY=...                    # REQUIRED

# ----- S3 Storage -----
# Single S3 bucket for all document storage (private uploads and public assets)
S3_BUCKET=your-sturtz-documents-bucket      # REQUIRED

# ----- Bedrock Models -----
BEDROCK_CHAT_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0  # optional
PAGEINDEX_MODEL=bedrock/global.anthropic.claude-sonnet-4-6              # optional

# ----- CORS -----
# Comma-separated origins allowed to call the API (e.g. https://chat.yourcompany.com)
# In Docker the chat-web nginx proxy runs on port 80, so the browser origin is http://localhost
CORS_ORIGINS=http://localhost               # optional, default: http://localhost (Docker)

# ----- Admin Seed -----
SEED_ADMIN_EMAIL=admin@sturtz.com            # optional
SEED_ADMIN_PASSWORD=changeme123              # CHANGE IN PRODUCTION

# ----- SMTP (optional — for ingestion failure alerts) -----
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=alerts@yourcompany.com
# SMTP_PASS=app_password_here
# SMTP_PORT=587
# SMTP_FROM=alerts@yourcompany.com
# APP_URL=https://chat.yourcompany.com
# ENABLE_INGESTION_FAILURE_ALERTS=true
